{
  "name": "@shreedhar/create-package",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "create-package": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "type-check": "tsc --project tests/tsconfig.json",
    "dev": "tsx ./src/cli/index.ts",
    "prepack": "npm run build",
    "start": "node ./dist/cli/index.js",
    "test": "node --import tsx --test ./tests/**/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
